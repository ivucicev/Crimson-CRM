# OPENAI_API_KEY: Required for OpenAI API calls.
OPENAI_API_KEY="MY_OPENAI_API_KEY"

# OPENAI_MODEL: Optional model override.
OPENAI_MODEL="gpt-4o-mini"

# SERPER_API_KEY: Required for live web-grounded people research.
# Get one from https://serper.dev
SERPER_API_KEY="MY_SERPER_API_KEY"

# Sudreg (Croatia public court registry) API credentials
# OpenAPI docs: https://sudreg-data.gov.hr/api/javni/dokumentacija/open_api
SUDREG_CLIENT_ID="YOUR_SUDREG_CLIENT_ID"
SUDREG_CLIENT_SECRET="YOUR_SUDREG_CLIENT_SECRET"
# Optional overrides:
SUDREG_BASE_URL="https://sudreg-data.gov.hr/api/javni"
SUDREG_TOKEN_URL="https://sudreg-data.gov.hr/api/oauth/token"
# Optional: Sudreg sync page size for /tvrtke (1-9999)
SUDREG_SYNC_PAGE_SIZE=5000
# Sync fetches detalji_subjekta with expand_relations=1 and caches full raw JSON.

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Email Configuration (Nodemailer)
# Configure these to enable sending emails directly from the CRM
EMAIL_HOST="smtp.example.com"
EMAIL_PORT=587
EMAIL_USER="your-email@example.com"
EMAIL_PASS="your-password"
EMAIL_FROM="Crimson CRM <noreply@example.com>"

# SQLite database file location (optional)
# Default: ./data/crimson.db
DATABASE_PATH="./data/crimson.db"
